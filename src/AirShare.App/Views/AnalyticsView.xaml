<UserControl x:Class="AirShare.App.Views.AnalyticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <StackPanel Margin="0,0,0,24">
                <TextBlock Text="Analytics &amp; Performance"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}"/>
                <TextBlock Text="Real-time latency and buffer health for active sharing sessions."
                           FontSize="16"
                           Foreground="{StaticResource MutedBrush}"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource StitchCard}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Connected Devices" Foreground="{StaticResource MutedBrush}"/>
                        <TextBlock Text="{Binding ConnectedDeviceCount}"
                                   FontSize="36"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource StitchCard}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Sharing Status" Foreground="{StaticResource MutedBrush}"/>
                        <TextBlock Text="{Binding StatusMessage}"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource StitchCard}">
                    <StackPanel>
                        <TextBlock Text="Master Volume" Foreground="{StaticResource MutedBrush}"/>
                        <TextBlock Text="{Binding MasterVolume, StringFormat={}{0}%}"
                                   FontSize="36"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource StitchCard}" Margin="0,24,0,0">
                <StackPanel>
                    <TextBlock Text="Per-Device Latency"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               Margin="0,0,0,16"/>
                    <ItemsControl ItemsSource="{Binding ActiveLatencyStats}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="{Binding DeviceName}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextBrush}"/>
                                        <ProgressBar Value="{Binding BufferFillPercent}"
                                                     Maximum="100"
                                                     Height="8"
                                                     Margin="0,8,0,0"/>
                                    </StackPanel>
                                    <StackPanel HorizontalAlignment="Right">
                                        <TextBlock HorizontalAlignment="Right" Foreground="{StaticResource PrimaryBrush}" FontWeight="Bold">
                                            <Run Text="{Binding LatencyMs, Mode=OneWay}"/>
                                            <Run Text=" ms"/>
                                        </TextBlock>
                                        <TextBlock HorizontalAlignment="Right"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   FontSize="12"
                                                   Text="{Binding BufferFillPercent, StringFormat=Buffer {0}%}"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="Start sharing to populate live latency metrics."
                               Foreground="{StaticResource MutedBrush}"
                               Visibility="{Binding IsSharing, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
