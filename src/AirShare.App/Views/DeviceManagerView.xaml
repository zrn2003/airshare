<UserControl x:Class="AirShare.App.Views.DeviceManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AirShare.App.ViewModels">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Grid Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="Device Manager"
                               FontSize="32"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}"/>
                    <TextBlock Text="Discover, select, and manage your audio output devices."
                               FontSize="16"
                               Foreground="{StaticResource MutedBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>
                <Button Content="Scan for Devices"
                        Style="{StaticResource StitchPrimaryButton}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Command="{Binding RefreshDevicesCommand}"/>
            </Grid>

            <Border Style="{StaticResource StitchCard}" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="Available Devices"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"/>
                    <TextBlock Text="{Binding ConnectedDeviceCount, StringFormat={}{0} devices detected}"
                               Foreground="{StaticResource MutedBrush}"
                               Margin="0,4,0,16"/>
                    <ItemsControl ItemsSource="{Binding Devices}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:DeviceItemViewModel}">
                                <Border Background="{StaticResource SurfaceContainerLowBrush}"
                                        CornerRadius="12"
                                        Padding="16"
                                        Margin="0,0,0,12"
                                        BorderBrush="{StaticResource SurfaceContainerHighBrush}"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox IsChecked="{Binding IsSelected}"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,16,0"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="Bold"
                                                       FontSize="16"
                                                       Foreground="{StaticResource TextBrush}"/>
                                            <TextBlock Text="{Binding Type}"
                                                       Foreground="{StaticResource MutedBrush}"/>
                                            <TextBlock Foreground="{StaticResource SecondaryBrush}" FontSize="12">
                                                <Run Text="{Binding LatencyMs, Mode=OneWay}"/>
                                                <Run Text=" ms latency"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Output volume"
                                                       FontSize="12"
                                                       Foreground="{StaticResource MutedBrush}"/>
                                            <Slider Minimum="0"
                                                    Maximum="100"
                                                    Value="{Binding Volume}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="3"
                                                   VerticalAlignment="Center"
                                                   Margin="16,0,0,0"
                                                   Foreground="{StaticResource SecondaryBrush}"
                                                   Text="Connected"
                                                   Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal">
                <Button Content="Start Sharing"
                        Style="{StaticResource StitchPrimaryButton}"
                        Command="{Binding StartSharingCommand}"
                        Visibility="{Binding IsSharing, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                <Button Content="Stop Sharing"
                        Background="{StaticResource ErrorBrush}"
                        Foreground="White"
                        Style="{StaticResource StitchPrimaryButton}"
                        Margin="12,0,0,0"
                        Command="{Binding StopSharingCommand}"
                        Visibility="{Binding IsSharing, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </StackPanel>
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{StaticResource ErrorBrush}"
                       Margin="0,12,0,0"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
