<UserControl x:Class="AirShare.App.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AirShare.App.ViewModels">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Grid Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="System Overview"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"/>
                    <TextBlock Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0">
                        <Run Text="Managing"/>
                        <Run Text="{Binding ConnectedDeviceCount, Mode=OneWay}"/>
                        <Run Text="connected output devices."/>
                    </TextBlock>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Refresh Devices"
                            Style="{StaticResource StitchSecondaryButton}"
                            Margin="0,0,12,0"
                            Command="{Binding RefreshDevicesCommand}"/>
                    <Button Content="Start Sharing"
                            Style="{StaticResource StitchPrimaryButton}"
                            Command="{Binding StartSharingCommand}"
                            Visibility="{Binding IsSharing, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                    <Button Content="Stop Sharing"
                            Background="{StaticResource ErrorBrush}"
                            Foreground="White"
                            Style="{StaticResource StitchPrimaryButton}"
                            Command="{Binding StopSharingCommand}"
                            Visibility="{Binding IsSharing, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource StitchCard}"
                        Margin="0,0,16,0"
                        MinHeight="320">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Ellipse Width="96" Height="96" Fill="{StaticResource PrimaryBrush}" Margin="0,0,0,20"/>
                        <TextBlock Text="{Binding StatusMessage}"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Your system audio is shared to selected output devices with latency compensation."
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   MaxWidth="420"
                                   Foreground="{StaticResource MutedBrush}"
                                   Margin="0,8,0,0"/>
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="{StaticResource ErrorBrush}"
                                   Margin="0,16,0,0"
                                   Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource StitchCard}">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <TextBlock Text="Performance"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"/>
                            <Border Background="{StaticResource SecondaryContainerBrush}"
                                    CornerRadius="8"
                                    Padding="8,4"
                                    HorizontalAlignment="Right">
                                <TextBlock Text="STABLE"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource SecondaryBrush}"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="Connected devices"
                                   Foreground="{StaticResource MutedBrush}"/>
                        <TextBlock Text="{Binding ConnectedDeviceCount}"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   Margin="0,4,0,16"/>
                        <TextBlock Text="Active latency streams"
                                   Foreground="{StaticResource MutedBrush}"
                                   Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding ActiveLatencyStats}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <TextBlock Text="{Binding DeviceName}" Foreground="{StaticResource TextBrush}"/>
                                        <TextBlock HorizontalAlignment="Right" Foreground="{StaticResource PrimaryBrush}">
                                            <Run Text="{Binding LatencyMs, Mode=OneWay}"/>
                                            <Run Text=" ms"/>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <TextBlock Text="Connected Sinks"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextBrush}"
                       Margin="0,24,0,12"/>

            <ItemsControl ItemsSource="{Binding Devices}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="3"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:DeviceItemViewModel}">
                        <Border Style="{StaticResource StitchCard}" Margin="0,0,12,12">
                            <StackPanel>
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource TextBrush}"/>
                                        <TextBlock Text="{Binding Type}"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   FontSize="12"/>
                                    </StackPanel>
                                    <TextBlock HorizontalAlignment="Right" Foreground="{StaticResource MutedBrush}" FontSize="12">
                                        <Run Text="{Binding LatencyMs, Mode=OneWay}"/>
                                        <Run Text="ms"/>
                                    </TextBlock>
                                </Grid>
                                <Slider Minimum="0"
                                        Maximum="100"
                                        Value="{Binding Volume}"
                                        Margin="0,16,0,0"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
